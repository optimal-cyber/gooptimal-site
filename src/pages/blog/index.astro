---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
const fmt = (d: Date) =>
  new Date(d).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Layout
  title="Blog — Optimal"
  description="Field notes on AI security, authorization, and getting software into the mission — FedRAMP, ATO, SBOM, and agentic AI."
>
  <Header />

  <section class="section relative">
    <div class="glow"></div>
    <div class="container z">
      <span class="eyebrow">Blog</span>
      <h1 class="h2">Field notes from the authorization frontier.</h1>
      <p class="lead" style="margin-top:14px;">
        AI security, ATO, FedRAMP, SBOM, and what it takes to ship software into regulated missions.
      </p>

      <div class="grid grid-3 posts">
        {posts.map((p) => (
          <a class="card post" href={`/blog/${p.id}`}>
            {p.data.image && (
              <div class="thumb">
                <img src={p.data.image} alt={p.data.imageAlt ?? p.data.title} loading="lazy" />
              </div>
            )}
            <span class="tag cat">{p.data.category}</span>
            <h3>{p.data.title}</h3>
            <p class="muted excerpt">{p.data.description}</p>
            <time class="date" datetime={new Date(p.data.date).toISOString()}>{fmt(p.data.date)}</time>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .posts { margin-top: 42px; }
  .post { display: flex; flex-direction: column; gap: 12px; text-decoration: none; overflow: hidden; }
  .post .thumb {
    margin: -28px -28px 4px;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-2);
    border-bottom: 1px solid var(--rule);
  }
  .post .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .3s ease; }
  .post:hover .thumb img { transform: scale(1.04); }
  .post .cat { align-self: flex-start; color: var(--sunset); border-color: color-mix(in srgb, var(--sunset) 35%, transparent); }
  .post h3 { font-size: 1.2rem; line-height: 1.25; }
  .post .excerpt { font-size: 14px; line-height: 1.6; flex: 1; }
  .post .date { font-size: 12px; color: var(--text-faint); font-family: var(--font-display); }
</style>
