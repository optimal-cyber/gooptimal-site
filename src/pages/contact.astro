---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GatewayCanvas from "../components/GatewayCanvas.astro";
import VetBadge from "../components/VetBadge.astro";
---

<Layout
  title="Book a scoping call — Optimal"
  description="Tell us your environment and the models you need. We'll stand up authorized, audited AI access across your clouds — GovCloud, on-prem, or air-gapped."
>
  <Header />

  <section class="section relative">
    <div class="glow"></div>
    <GatewayCanvas variant="ambient" align="center" density={0.55} />
    <div class="container z wrap">
      <div class="intro">
        <span class="eyebrow">Book a scoping call</span>
        <h1 class="h2">Let&rsquo;s scope your AI security engagement.</h1>
        <p class="lead" style="margin-top:16px;">
          Tell us your environment, the models you&rsquo;re adopting, and where
          you&rsquo;re worried. We&rsquo;ll scope the right engagement — assessment,
          red team, governed engineering, or advisory — across GovCloud, on-prem,
          or air-gapped.
        </p>
        <p class="muted email">
          Prefer email? <a href="mailto:ryan@gooptimal.io">ryan@gooptimal.io</a>
        </p>
        <div class="vet-wrap">
          <VetBadge size={92} />
          <p class="muted vet-note">
            Optimal, LLC is an SBA-certified Service-Disabled Veteran-Owned Small
            Business (SDVOSB), eligible for SDVOSB and VOSB set-aside contracts.
          </p>
        </div>
      </div>

      <form class="card form" method="POST" action="https://formspree.io/f/xovqzpkj">
        <!-- Formspree config: email subject + honeypot spam trap -->
        <input type="hidden" name="_subject" value="Optimal · Scoping call request" />
        <input type="text" name="_gotcha" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="row">
          <label>Name<input type="text" name="name" required /></label>
          <label>Work email<input type="email" name="email" required /></label>
        </div>
        <div class="row">
          <label>Organization<input type="text" name="organization" /></label>
          <label>Environment
            <select name="boundary">
              <option>Commercial</option>
              <option>FedRAMP</option>
              <option>IL4 / IL5</option>
              <option>IL6</option>
              <option>On-prem / air-gapped</option>
            </select>
          </label>
        </div>
        <label>What do you need?<textarea name="message" rows="4" placeholder="Models, clouds, timeline…"></textarea></label>
        <button type="submit" class="btn btn-primary">Send request →</button>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .wrap { display: grid; gap: 40px; align-items: start; }
  .intro { padding-top: 6px; }
  .email { margin-top: 22px; font-size: 14px; }
  .email a { color: var(--sunset); }
  .vet-wrap { margin-top: 28px; padding-top: 24px; border-top: 1px solid var(--rule); display: flex; flex-wrap: wrap; align-items: center; gap: 18px; }
  .vet-wrap .vet-note { font-size: 13px; max-width: 34ch; flex: 1 1 220px; }
  .form { display: grid; gap: 16px; }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .row { display: grid; gap: 16px; }
  label { display: grid; gap: 7px; font-size: 13px; color: var(--text-dim); }
  input, select, textarea {
    width: 100%; font: inherit; color: var(--text);
    background: var(--bg); border: 1px solid var(--rule); border-radius: var(--radius-sm);
    padding: 11px 13px; outline: none; transition: border-color .2s ease;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--sunset); }
  .form .btn { justify-self: start; margin-top: 6px; }
  @media (min-width: 900px) {
    .wrap { grid-template-columns: 1fr 1fr; gap: 64px; }
    .row { grid-template-columns: 1fr 1fr; }
  }
</style>
