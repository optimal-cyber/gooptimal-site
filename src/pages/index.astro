---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GatewayCanvas from "../components/GatewayCanvas.astro";
import VetBadge from "../components/VetBadge.astro";

const standards = [
  "NIST AI RMF", "OWASP LLM Top 10", "MITRE ATLAS", "NIST 800-207 Zero Trust",
  "CIS Benchmarks", "DISA STIG", "ISO 42001", "SOC 2",
];

const capabilities = [
  {
    k: "01",
    title: "One authenticated gateway",
    body: "Point your existing OpenAI- or Anthropic-compatible client at a single governed endpoint. Cloudflare Access and Okta OIDC authenticate the caller; LiteLLM fans out to every frontier model behind per-key virtual credentials — no SDK rewrite.",
    accent: "var(--sunset)",
  },
  {
    k: "02",
    title: "Guardrails on every prompt",
    body: "NeMo Guardrails runs fail-closed and pre-call: unit-tested secret and PII detectors block a request before the provider is ever reached, and injection and jailbreak patterns are caught inline on the way in and out.",
    accent: "var(--steel)",
  },
  {
    k: "03",
    title: "Default-deny by design",
    body: "Egress is pinned to an allowlist by a Squid proxy and security-group rules — there is no configuration opt-out. IMDSv2, no inbound SSH, and least-privilege identity throughout.",
    accent: "var(--coral)",
  },
  {
    k: "04",
    title: "An audit trail that holds up",
    body: "Every request and every token lands in structured JSON paired with Postgres rows, joined by a request ID — a defensible evidence trail your reviewers read directly, not a wall of vendor-UI screenshots.",
    accent: "var(--seafoam)",
  },
];

const flow = [
  { n: "Authorize", d: "Authenticate the caller through Cloudflare Access and Okta OIDC, then check the model and resource allowlist." },
  { n: "Guard", d: "Inline detection on prompt and response — injection, jailbreak, PII / DLP, secret exfiltration. Fail-closed." },
  { n: "Forward", d: "Proxy to the approved model — commercial, GovCloud, or self-hosted — through per-key LiteLLM virtual credentials." },
  { n: "Prove", d: "Write a structured audit row — JSON plus Postgres, joined by request ID — that you can hand to a reviewer." },
];

const work = [
  {
    tag: "Regulated cloud",
    title: "Governed AI inside the cloud you already operate",
    body: "Route agents and users to approved models with a full audit trail. Every request authorized, every token logged — without standing up a new accreditation boundary.",
    href: "/use-cases/regulated-cloud",
    cta: "Regulated cloud →",
  },
  {
    tag: "On-prem & air-gapped",
    title: "Frontier-class AI with zero egress",
    body: "Self-host the gateway and models where nothing leaves the wire. Default-deny egress is structural, not a checkbox — the same control bands, fully disconnected.",
    href: "/use-cases/air-gapped",
    cta: "On-prem & air-gapped →",
  },
  {
    tag: "Agentic workloads",
    title: "Keep autonomous agents accountable",
    body: "Per-key identity and rate limits, model and tool allowlists, and an audit of every call an agent makes — so autonomy never means unaccountable.",
    href: "/use-cases/agentic",
    cta: "Agentic workloads →",
  },
];
---

<Layout>
  <Header />

  <!-- HERO -->
  <section class="hero relative">
    <div class="glow"></div>
    <GatewayCanvas variant="hero" />
    <div class="container z">
      <span class="eyebrow">Secure AI engineering for regulated &amp; federal missions</span>
      <h1 class="display">Ship AI into the mission,<br /><span class="grad">not around the rules.</span></h1>
      <p class="lead">
        Optimal stands up governed, audited AI inside your environment — one authenticated
        gateway to every frontier model, guardrails on every prompt, and an audit trail you
        can defend. Across GovCloud, on-prem, and air-gapped.
      </p>
      <div class="cta-row">
        <a href="/contact" class="btn btn-primary">Book a scoping call →</a>
        <a href="#how" class="btn btn-ghost">See how we work</a>
      </div>
      <div class="hero-meta muted">
        <span>Self-hosted in your cloud</span><span class="dot">•</span>
        <span>Sovereign by default</span><span class="dot">•</span>
        <span>Open-source reference architecture</span>
      </div>
    </div>
  </section>

  <!-- STANDARDS WALL (logo wall analogue) -->
  <section id="standards" class="section--tight standards">
    <div class="container">
      <p class="wall-label muted">Engineered to the standards that gate production AI</p>
      <div class="wall">
        {standards.map((s) => <span class="chip">{s}</span>)}
      </div>
      <div class="vet-strip">
        <VetBadge size={84} />
        <p class="vet-note muted">
          Optimal, LLC is a <strong>Service-Disabled Veteran-Owned Small Business</strong> —
          SBA-certified and eligible for veteran set-aside contracts.
        </p>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section id="capabilities" class="section">
    <div class="container">
      <span class="eyebrow">What we build</span>
      <h2 class="h2">One governed boundary over every model call.</h2>
      <p class="lead" style="margin-top:14px;">We stand up the pattern in your environment — the front door, the guardrails, the locked perimeter, and the audit trail for AI in regulated settings.</p>
      <div class="grid grid-2" style="margin-top:42px;">
        {capabilities.map((c) => (
          <div class="card cap">
            <div class="cap-k" style={`color:${c.accent}`}>{c.k}</div>
            <h3>{c.title}</h3>
            <p class="muted">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="section how relative">
    <div class="glow"></div>
    <div class="container z">
      <span class="eyebrow">How we work</span>
      <h2 class="h2">Agents in. Approved resources out.<br />Everything in between, governed.</h2>
      <div class="flow">
        {flow.map((f, i) => (
          <div class="step">
            <div class="step-n">{String(i + 1).padStart(2, "0")}</div>
            <h4>{f.n}</h4>
            <p class="muted">{f.d}</p>
          </div>
        ))}
      </div>
      <p class="muted note">No wrapper, no SDK rewrite — point your existing OpenAI- or Anthropic-compatible client at the gateway and every call is governed and logged.</p>
    </div>
  </section>

  <!-- USE CASES -->
  <section id="work" class="section">
    <div class="container">
      <span class="eyebrow">Use cases</span>
      <h2 class="h2">Built for the missions that can&rsquo;t get it wrong.</h2>
      <div class="grid grid-3" style="margin-top:42px;">
        {work.map((w) => (
          <div class="card usecase">
            <span class="tag">{w.tag}</span>
            <h3>{w.title}</h3>
            <p class="muted">{w.body}</p>
            <a href={w.href} class="usecase-link">{w.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="section--tight">
    <div class="container">
      <blockquote class="quote">
        <p>&ldquo;The audit is the point. Every authorization decision and model call lands in a structured, append-only log — joined by request ID, and defensible on its own.&rdquo;</p>
        <footer class="muted">Optimal — the access layer, not another dashboard.</footer>
      </blockquote>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta relative">
    <div class="glow"></div>
    <GatewayCanvas variant="ambient" align="center" density={0.7} />
    <div class="container z cta-inner">
      <h2 class="display" style="font-size:clamp(2rem,5vw,3.4rem);">Bring your organization<br />through the Gateway.</h2>
      <p class="lead" style="margin:18px auto 0;">Tell us your environment and the models you need. We&rsquo;ll stand up authorized, audited access across your clouds — GovCloud, on-prem, or air-gapped.</p>
      <a href="/contact" class="btn btn-primary" style="margin-top:28px;">Book a scoping call →</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* HERO */
  .hero { padding: clamp(72px, 12vw, 150px) 0 clamp(48px, 7vw, 90px); }
  .hero .eyebrow { margin-bottom: 22px; }
  .hero h1 { margin-bottom: 24px; }
  .hero .lead { font-size: clamp(17px, 2.2vw, 21px); }
  .cta-row { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 34px; }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-top: 30px; font-size: 13px; }
  .hero-meta .dot { opacity: 0.4; }

  /* STANDARDS WALL */
  .standards { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--surface); }
  .wall-label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.16em; text-align: center; margin-bottom: 22px; }
  .wall { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .chip {
    font-family: var(--font-display); font-weight: 500; font-size: 14px;
    color: var(--text-dim); border: 1px solid var(--rule); border-radius: 999px;
    padding: 8px 16px; transition: color .2s, border-color .2s;
  }
  .chip:hover { color: var(--text); border-color: var(--rule-strong); }
  .vet-strip {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 14px 18px; margin-top: 26px; padding-top: 24px;
    border-top: 1px solid var(--rule);
  }
  .vet-note { font-size: 13px; max-width: 52ch; text-align: center; }
  .vet-note strong { color: var(--text); font-weight: 600; }

  /* CAPABILITIES */
  .cap-k { font-family: var(--font-display); font-size: 13px; font-weight: 700; letter-spacing: 0.1em; margin-bottom: 14px; }
  .cap h3 { font-size: 1.35rem; margin-bottom: 10px; }
  .cap p { font-size: 15px; line-height: 1.7; }

  /* HOW */
  .how { background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .flow { display: grid; gap: 20px; margin-top: 42px; }
  .step { padding: 24px; border: 1px solid var(--rule); border-radius: var(--radius); background: var(--surface-2); }
  .step-n { font-family: var(--font-display); font-weight: 700; color: var(--sunset); font-size: 14px; letter-spacing: 0.1em; margin-bottom: 12px; }
  .step h4 { font-size: 1.15rem; margin-bottom: 8px; }
  .step p { font-size: 14px; line-height: 1.65; }
  .note { margin-top: 28px; font-size: 14px; max-width: 70ch; }
  @media (min-width: 860px) { .flow { grid-template-columns: repeat(4, 1fr); } }

  /* USE CASES */
  .usecase h3 { font-size: 1.2rem; margin: 14px 0 10px; }
  .usecase p { font-size: 14px; line-height: 1.7; }
  .usecase-link { display: inline-block; margin-top: 16px; color: var(--sunset); font-size: 14px; font-weight: 600; }
  .usecase-link:hover { color: var(--ember); }

  /* QUOTE */
  .quote { margin: 0; border-left: 3px solid var(--sunset); padding: 6px 0 6px 28px; max-width: 60ch; }
  .quote p { font-family: var(--font-display); font-size: clamp(1.2rem, 2.6vw, 1.8rem); line-height: 1.35; letter-spacing: -0.02em; }
  .quote footer { margin-top: 16px; font-size: 14px; }

  /* CTA */
  .cta { background: var(--surface); border-top: 1px solid var(--rule); }
  .cta-inner { text-align: center; max-width: 720px; margin: 0 auto; }
</style>
