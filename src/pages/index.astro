---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GatewayCanvas from "../components/GatewayCanvas.astro";
import VetBadge from "../components/VetBadge.astro";

const standards = [
  "NIST AI RMF", "OWASP LLM Top 10", "MITRE ATLAS", "NIST 800-207",
  "CIS Benchmarks", "DISA STIG", "ISO 42001", "SOC 2",
];

// The two pillars — the compliant environment, and the governed AI inside it.
const pillars = [
  {
    tag: "Managed environment",
    title: "CMMC-ready GCC High enclaves",
    body: "We stand up your Microsoft 365 GCC High tenant, migrate your people and data into it, engineer the NIST 800-171 controls, and run it for you — so you stay eligible to win and keep DoD work that touches CUI or ITAR-controlled data.",
    points: ["Design, build & migration", "NIST 800-171 / CMMC L2 alignment", "Fully managed operations", "GCC High G5 licensing"],
    href: "/gcc-high",
    cta: "Managed GCC High →",
  },
  {
    tag: "Governed intelligence",
    title: "AI you can actually use on the mission",
    body: "Most GCC High shops stop at email and files. We stand up governed access to the frontier models authorized for your sovereign cloud — one gateway, fail-closed guardrails, a defensible audit trail — plus assessment and red-teaming of the AI you deploy.",
    points: ["Governed AI gateway", "Adversarial AI red-teaming", "AI security assessments", "Secure-adoption advisory"],
    href: "#services",
    cta: "AI security services →",
  },
];

// Managed GCC High — the four bands of the managed service.
const gccBands = [
  { idx: "01", n: "Build the enclave", d: "A compliant Microsoft 365 GCC High tenant — Entra ID, Conditional Access, Defender, and Purview configured to a CUI-ready baseline from day one." },
  { idx: "02", n: "Migrate cleanly", d: "Mailboxes, files, Teams, and identities moved from Commercial or GCC into GCC High with spillage controls — no CUI left in the wrong boundary." },
  { idx: "03", n: "Engineer the controls", d: "The NIST SP 800-171 control set implemented and documented — SSP and POA&M, evidence collected, ready for your C3PAO's CMMC Level 2 assessment." },
  { idx: "04", n: "Run it for you", d: "Ongoing administration, patching, monitoring, user lifecycle, and help desk — the managed operations that keep the enclave compliant after go-live." },
];

// Advisory-led services — the four engagements Optimal runs, arced
// find it → prove it → build the controls → keep the program governed.
// Each carries concrete scope and a named deliverable, not benefit copy.
const services = [
  {
    idx: "01",
    title: "AI Security Assessment",
    accent: "var(--sunset)",
    lede: "A structured evaluation of the AI systems you're putting into production — models, prompts, retrieval, tool calls, identities, and the plumbing around them. We map the attack paths an adversary would actually take, not a control checklist.",
    scopeLabel: "We examine",
    scope: [
      "System- and user-prompt trust boundaries",
      "Retrieval / RAG pipelines and context injection",
      "Tool- and function-call authorization",
      "Model output handling and downstream sinks",
      "Secrets, PII, and training-data exposure",
    ],
    outcome:
      "Findings mapped to the OWASP LLM Top 10 and MITRE ATLAS, ranked attack narratives with reproduction steps, prioritized remediation, and a retest.",
  },
  {
    idx: "02",
    title: "Adversarial AI Testing",
    accent: "var(--steel)",
    lede: "Offensive, hands-on testing of AI-enabled systems and agents. We operate the way an adversary would, then show you exactly how a failure happens — and the specific control that closes it.",
    scopeLabel: "We attempt",
    scope: [
      "Direct and indirect prompt injection",
      "Jailbreaks and system-prompt extraction",
      "Model and context manipulation",
      "Data, secret, and model exfiltration",
      "Agent abuse and excessive-agency chains",
    ],
    outcome:
      "Reproducible attack chains with evidence, impact rated to your environment, and the control that would have stopped each one.",
  },
  {
    idx: "03",
    title: "Governed AI Engineering",
    accent: "var(--coral)",
    lede: "Our signature engagement. We design and stand up the access layer for AI in the cloud you already license — Azure, AWS, GCP, or GovCloud — built on our open-source Zero Trust reference architecture.",
    scopeLabel: "We build",
    scope: [
      "One authenticated gateway to every approved model — Azure OpenAI, Bedrock, Vertex, or self-hosted",
      "Per-key virtual credentials and rate limits",
      "Fail-closed prompt and response guardrails",
      "Default-deny egress, pinned to an allowlist",
      "A request-ID-joined audit trail reviewers read directly",
    ],
    outcome:
      "A governed, self-hostable control plane you own and operate — no SDK rewrite, no vendor lock-in, no new accreditation boundary.",
  },
  {
    idx: "04",
    title: "Secure AI Adoption Advisory",
    accent: "var(--seafoam)",
    lede: "Help your teams adopt AI without flying blind. Engineering-grounded guidance scoped to your risk profile and grounded in real attack paths — not paperwork.",
    scopeLabel: "We deliver",
    scope: [
      "AI usage patterns and acceptable-use guardrails",
      "Threat models for your specific AI workloads",
      "A secure-adoption roadmap tied to real risk",
      "Reference designs your engineers can follow",
      "Working sessions with the teams shipping AI",
    ],
    outcome:
      "Your people know the guardrails and why they exist; you get the evidence they held.",
  },
];

// Standard security-assessment methodology, written to AI systems.
const phases = [
  {
    idx: "01",
    n: "Scope",
    d: "We define the systems in play, the data they touch, the threat model that actually matters to you, and the rules of engagement. The scope is written to your stack — not lifted from a template.",
  },
  {
    idx: "02",
    n: "Map the attack surface",
    d: "We inventory every way in and out: models, prompts, retrieval sources, tools and functions, identities, credentials, and egress paths. You can't secure what hasn't been mapped.",
  },
  {
    idx: "03",
    n: "Test like an adversary",
    d: "We run the OWASP LLM Top 10 and MITRE ATLAS techniques against your systems — injection, extraction, manipulation, abuse-case chains — and document what works, with evidence.",
  },
  {
    idx: "04",
    n: "Report for two audiences",
    d: "Ranked findings, reproduction steps, business impact, and specific remediation — written for the engineers who fix it and the leaders who own the risk.",
  },
  {
    idx: "05",
    n: "Remediate & retest",
    d: "We help close the findings, then prove they're closed. The engagement ends with evidence, not a backlog of open items.",
  },
];

// OWASP Top 10 for LLM Applications (2025) — the threat taxonomy we test to.
const owasp = [
  ["LLM01", "Prompt Injection"],
  ["LLM02", "Sensitive Information Disclosure"],
  ["LLM03", "Supply Chain"],
  ["LLM04", "Data & Model Poisoning"],
  ["LLM05", "Improper Output Handling"],
  ["LLM06", "Excessive Agency"],
  ["LLM07", "System Prompt Leakage"],
  ["LLM08", "Vector & Embedding Weaknesses"],
  ["LLM09", "Misinformation"],
  ["LLM10", "Unbounded Consumption"],
];

const flow = [
  {
    idx: "01",
    n: "Authorize",
    stack: "Cloudflare Access · Okta OIDC",
    d: "Authenticate the caller, then check the request against a model and resource allowlist. No token is issued for a model you haven't approved.",
  },
  {
    idx: "02",
    n: "Guard",
    stack: "NeMo Guardrails · PII/secret detectors",
    d: "Inline detection on prompt and response — injection, jailbreak, PII/DLP, secret exfiltration — fail-closed and pre-call. A blocked request never reaches the provider.",
  },
  {
    idx: "03",
    n: "Forward",
    stack: "LiteLLM keys · Squid egress",
    d: "Proxy to the approved model — commercial, GovCloud, or self-hosted — through per-key virtual credentials, with egress pinned to a default-deny allowlist.",
  },
  {
    idx: "04",
    n: "Prove",
    stack: "Structured JSON · Postgres",
    d: "Write a structured audit row joined by request ID — the artifact your reviewers read directly, on your retention, in your account.",
  },
];

const work = [
  {
    tag: "Regulated cloud",
    title: "Governed AI inside the cloud you already operate",
    body: "Route agents and users to approved models with a full audit trail. Every request authorized, every token logged — without standing up a new accreditation boundary.",
    href: "/use-cases/regulated-cloud",
    cta: "Regulated cloud →",
  },
  {
    tag: "On-prem & air-gapped",
    title: "Frontier-class AI with zero egress",
    body: "Self-host the gateway and models where nothing leaves the wire. Default-deny egress is structural, not a checkbox — the same control bands, fully disconnected.",
    href: "/use-cases/air-gapped",
    cta: "On-prem & air-gapped →",
  },
  {
    tag: "Agentic workloads",
    title: "Keep autonomous agents accountable",
    body: "Per-key identity and rate limits, model and tool allowlists, and an audit of every call an agent makes — so autonomy never means unaccountable.",
    href: "/use-cases/agentic",
    cta: "Agentic workloads →",
  },
];

const faqs = [
  {
    q: "What does Optimal do?",
    a: "Optimal does two things that work together. First, we build, migrate, and manage CMMC-ready Microsoft 365 GCC High enclaves for the defense industrial base — the sovereign environment you need to handle CUI and ITAR-controlled data on DoD contracts. Second, we stand up the governed AI that runs safely inside those environments, and assess and red-team the AI systems teams deploy. We're an SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB).",
  },
  {
    q: "What is Microsoft 365 GCC High, and do I need it?",
    a: "GCC High is a US-sovereign version of Microsoft 365, physically and logically isolated, with US data residency and screened US-person support. If you're a defense contractor handling Controlled Unclassified Information (CUI) or ITAR/export-controlled data, GCC High is the environment built to support the DFARS 252.204-7012 and CMMC Level 2 obligations in your contracts. Optimal stands the enclave up and runs it for you.",
  },
  {
    q: "Does moving to GCC High make me CMMC compliant?",
    a: "No environment makes you compliant on its own — CMMC Level 2 is a third-party assessment against the 110 NIST SP 800-171 controls. What GCC High gives you is a foundation built for those controls. Optimal implements and documents the control set inside your enclave (SSP and POA&M), collects the evidence, and gets you assessment-ready. The certified assessment itself is performed independently by an accredited C3PAO — we prepare the environment, we don't grade it.",
  },
  {
    q: "Is Optimal a product company or a services firm?",
    a: "Advisory-led. We deliver engagements, not a SaaS subscription. The control pattern we implement is published as an open-source Zero Trust reference architecture — so you can read exactly what we build before we build it, and keep operating it yourself afterward.",
  },
  {
    q: "How do you test AI systems for vulnerabilities?",
    a: "We test real attack paths — prompt injection, model and context manipulation, data and secret extraction, and abuse-case simulation — scoped to your specific environment and risk profile rather than a generic checklist. Findings are measured against the OWASP LLM Top 10 and MITRE ATLAS and come with the evidence and the fix.",
  },
  {
    q: "What is prompt injection, and why does it matter?",
    a: "Prompt injection manipulates an AI system through crafted input, causing it to ignore its instructions, expose data, or take actions it shouldn't. It's one of the most active threats facing any organization deploying large language models and agents — and one of the first things we test.",
  },
  {
    q: "How do you help teams adopt AI safely?",
    a: "We build practical, engineering-grounded usage patterns, threat models, and secure-adoption roadmaps tied to real-world risk. We review how AI is actually being used, identify where data and access are exposed, and give your teams guardrails they can follow — so adoption moves fast without moving blind.",
  },
  {
    q: "We already have Azure, AWS, or GCP — can you work in our cloud?",
    a: "Yes, and it's often the fastest path. We build governed, audited access to the frontier models already available in the cloud you license — Azure OpenAI Service, Amazon Bedrock, and Google Vertex AI — so your teams reach them safely without a new vendor or procurement. It's available to enterprises and to all of SLED (state, local, and education), as well as federal teams.",
  },
  {
    q: "Can Optimal work with federal, SLED, and enterprise teams?",
    a: "Yes. Optimal is an SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB), eligible for SDVOSB and VOSB set-aside contracts, and works with federal agencies, SLED (state, local, and education) entities, and enterprises. We deliver across GovCloud, commercial cloud (Azure, AWS, GCP), on-prem, and fully air-gapped networks.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title="Optimal — Managed GCC High enclaves & governed AI for the defense industrial base"
  description="Optimal builds, migrates, and manages CMMC-ready Microsoft 365 GCC High enclaves for the defense industrial base — and stands up the governed AI that runs safely inside them. Aligned to DFARS 252.204-7012, NIST SP 800-171, and CMMC Level 2, with support for CUI and ITAR-controlled data. An SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB)."
>
  <Header />

  <!-- HERO -->
  <section class="hero relative">
    <div class="glow"></div>
    <GatewayCanvas variant="hero" />
    <div class="container z">
      <span class="eyebrow">Managed GCC High · Governed AI · SDVOSB</span>
      <h1 class="display">The sovereign environment<br /><span class="grad">your mission runs on.</span></h1>
      <p class="lead">
        Optimal builds, migrates, and manages CMMC-ready Microsoft&nbsp;365 GCC&nbsp;High enclaves for
        the defense industrial base — and stands up the governed AI that runs safely inside them.
        One veteran-owned partner for the compliant cloud and the intelligence on top of it.
      </p>
      <p class="hero-caps">
        GCC&nbsp;High enclave <span>/</span> CMMC readiness <span>/</span> Governed AI <span>/</span> Red team
      </p>
      <div class="cta-row">
        <a href="/contact" class="btn btn-primary">Book a scoping call →</a>
        <a href="/gcc-high" class="btn btn-ghost">Explore managed GCC High</a>
      </div>
      <div class="hero-meta muted">
        <span>Sovereign by default</span><span class="dot">•</span>
        <span>CUI &amp; ITAR-ready</span><span class="dot">•</span>
        <span>SDVOSB-certified</span>
      </div>
    </div>
  </section>

  <!-- STANDARDS WALL + VET STRIP -->
  <section id="standards" class="section--tight standards">
    <div class="container">
      <p class="wall-label muted">Engineered and measured to the standards that gate production AI</p>
      <div class="wall">
        {standards.map((s) => <span class="chip">{s}</span>)}
      </div>
      <div class="vet-strip">
        <VetBadge size={84} />
        <p class="vet-note muted">
          Optimal, LLC is a <strong>Service-Disabled Veteran-Owned Small Business</strong> —
          SBA-certified and eligible for veteran set-aside contracts.
        </p>
      </div>
    </div>
  </section>

  <!-- PILLARS — what Optimal does, at a glance -->
  <section id="pillars" class="section pillars relative">
    <div class="glow"></div>
    <div class="container z">
      <div class="sec-head wide">
        <span class="ix">What we do</span>
        <h2 class="h2">Two things, built to work together.</h2>
        <p class="lead" style="margin-top:14px;">Optimal gives the defense industrial base a compliant place to operate — and the governed AI to operate faster inside it. The sovereign cloud and the intelligence on top of it, from one veteran-owned partner.</p>
      </div>
      <div class="pillar-grid">
        {pillars.map((p) => (
          <article class="card pillar">
            <span class="tag">{p.tag}</span>
            <h3>{p.title}</h3>
            <p class="muted pillar-body">{p.body}</p>
            <ul class="pillar-points">
              {p.points.map((pt) => <li>{pt}</li>)}
            </ul>
            <a href={p.href} class="usecase-link">{p.cta}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MANAGED GCC HIGH -->
  <section id="gcc-high" class="section gcc relative">
    <div class="glow"></div>
    <div class="container z">
      <div class="sec-head wide">
        <span class="ix">Managed GCC High · For the DIB</span>
        <h2 class="h2">A CMMC-ready enclave, built and run for you.</h2>
        <p class="lead" style="margin-top:14px;">If you handle CUI or ITAR-controlled data on a DoD contract, you need a sovereign environment that meets DFARS 252.204-7012 and CMMC Level 2. Optimal stands up your Microsoft&nbsp;365 GCC&nbsp;High enclave, migrates you into it, engineers the controls, and manages it — so compliance stops being the thing that costs you the contract. <a class="inline-link" href="/gcc-high">See the full managed service →</a></p>
      </div>
      <ol class="gcc-flow">
        {gccBands.map((b) => (
          <li class="gcc-step">
            <span class="gcc-ix">{b.idx}</span>
            <div>
              <h4>{b.n}</h4>
              <p class="muted">{b.d}</p>
            </div>
          </li>
        ))}
      </ol>
      <p class="muted note">GCC High G5 licensing and provisioning included. Optimal prepares and manages the environment; the certified CMMC assessment is performed independently by your C3PAO.</p>
    </div>
  </section>

  <!-- APPROACH / PHILOSOPHY -->
  <section id="approach" class="section approach relative">
    <div class="glow"></div>
    <div class="container z sec-split">
      <div class="sec-head">
        <span class="ix">01 / Approach</span>
        <h2 class="h2">Adversary-informed,<br />not compliance-driven.</h2>
      </div>
      <div class="approach-body">
        <p>
          Most teams meet AI security through a checklist. We start from the adversary — how a prompt
          gets injected, how a model leaks its own context, how an agent is talked into acting outside
          its lane. Compliance frameworks are where we finish, engineering targets we build toward,
          never where we begin.
        </p>
        <p>
          Expertise leads every engagement. We use AI and our own open-source tooling to move
          faster, but the judgment — what to test, what a finding means, what to build — stays human.
          We don't hand you a product and walk away. We scope to your stack, your risk, and your
          environment, and leave you able to run what we build.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="section">
    <div class="container">
      <div class="sec-head wide">
        <span class="ix">02 / Services</span>
        <h2 class="h2">Four ways we secure AI for the mission.</h2>
        <p class="lead" style="margin-top:14px;">Assess it the way an adversary would. Prove the failure. Engineer the controls that stop it. Keep the whole program governed. Engagements are scoped to your stack — most run four to eight weeks.</p>
      </div>
      <div class="svc-grid">
        {services.map((s) => (
          <article class="card svc">
            <header class="svc-top">
              <span class="svc-ix" style={`color:${s.accent}`}>{s.idx}</span>
              <h3>{s.title}</h3>
            </header>
            <p class="muted svc-lede">{s.lede}</p>
            <div class="svc-scope">
              <span class="scope-label" style={`color:${s.accent}`}>{s.scopeLabel}</span>
              <ul>
                {s.scope.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <p class="svc-outcome"><span class="muted">Deliverable</span> {s.outcome}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- THREAT COVERAGE — OWASP LLM TOP 10 -->
  <section id="coverage" class="section--tight coverage relative">
    <div class="container z">
      <div class="cov-head">
        <span class="ix">Threat coverage</span>
        <h3 class="cov-title">We test to the OWASP Top&nbsp;10 for LLM Applications —<br class="dtop" /> and the MITRE ATLAS techniques behind them.</h3>
      </div>
      <ul class="owasp">
        {owasp.map(([code, name]) => (
          <li class="owasp-item">
            <span class="owasp-code">{code}</span>
            <span class="owasp-name">{name}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- METHODOLOGY / PROCESS -->
  <section id="process" class="section process relative">
    <div class="glow"></div>
    <div class="container z">
      <div class="sec-head wide">
        <span class="ix">03 / Process</span>
        <h2 class="h2">How an engagement runs.</h2>
        <p class="lead" style="margin-top:14px;">A working method, not a black box. You see the attack surface as we map it, the findings as we prove them, and the fixes as they close.</p>
      </div>
      <ol class="timeline">
        {phases.map((p) => (
          <li class="phase">
            <div class="phase-node"><span>{p.idx}</span></div>
            <div class="phase-body">
              <h4>{p.n}</h4>
              <p class="muted">{p.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ARCHITECTURE / HOW IT WORKS -->
  <section id="how" class="section how relative">
    <div class="glow"></div>
    <div class="container z">
      <div class="sec-head wide">
        <span class="ix">04 / Architecture</span>
        <h2 class="h2">Agents in. Approved resources out.<br />Everything in between, governed.</h2>
        <p class="lead" style="margin-top:14px;">The reference pattern behind our Governed AI Engineering work — the same open-source Zero Trust design we stand up in your environment. <a class="inline-link" href="https://github.com/optimal-cyber/AI-Gateway">Read the architecture ↗</a></p>
      </div>
      <div class="flow">
        {flow.map((f) => (
          <div class="step">
            <div class="step-n">{f.idx}</div>
            <h4>{f.n}</h4>
            <p class="step-stack">{f.stack}</p>
            <p class="muted">{f.d}</p>
          </div>
        ))}
      </div>
      <p class="muted note">No wrapper, no SDK rewrite — point your existing OpenAI- or Anthropic-compatible client at the gateway and every call is governed and logged.</p>
    </div>
  </section>

  <!-- BRING YOUR OWN CLOUD -->
  <section id="cloud" class="section byoc relative">
    <div class="glow"></div>
    <div class="container z">
      <div class="sec-head wide">
        <span class="ix">Bring your own cloud</span>
        <h2 class="h2">Already licensed with Azure, AWS, or GCP?<br />We build the governed access on top.</h2>
        <p class="lead" style="margin-top:14px;">You don&rsquo;t need a new vendor to reach frontier models safely. If you already run Microsoft Azure, Amazon Web Services, or Google Cloud, Optimal stands up governed, audited access to the frontier models in the cloud you already license — the same authenticated gateway, guardrails, and defensible audit trail. Built for enterprises and for all of SLED: state, local, and education.</p>
      </div>
      <ul class="clouds">
        <li class="cloud-item">
          <span class="cloud-name">Microsoft Azure</span>
          <span class="cloud-svc">Azure OpenAI Service</span>
        </li>
        <li class="cloud-item">
          <span class="cloud-name">Amazon Web Services</span>
          <span class="cloud-svc">Amazon Bedrock</span>
        </li>
        <li class="cloud-item">
          <span class="cloud-name">Google Cloud</span>
          <span class="cloud-svc">Vertex AI</span>
        </li>
      </ul>
      <p class="muted byoc-note">Reach for the models in the cloud you already pay for — or self-host them. Either way, every call runs through one governed boundary with a defensible audit trail.</p>
    </div>
  </section>

  <!-- USE CASES -->
  <section id="work" class="section">
    <div class="container">
      <div class="sec-head wide">
        <span class="ix">05 / Use cases</span>
        <h2 class="h2">Built for the missions that can&rsquo;t get it wrong.</h2>
      </div>
      <div class="grid grid-3" style="margin-top:38px;">
        {work.map((w) => (
          <div class="card usecase">
            <span class="tag">{w.tag}</span>
            <h3>{w.title}</h3>
            <p class="muted">{w.body}</p>
            <a href={w.href} class="usecase-link">{w.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NINELINE REFERENCE IMPLEMENTATION -->
  <section id="nineline" class="section--tight nl-teaser relative">
    <div class="glow"></div>
    <div class="container z nl-inner">
      <div class="nl-copy">
        <span class="ix">Reference implementation</span>
        <h2 class="h2">NINELINE — our 9-line for software and AI.</h2>
        <p class="lead" style="margin-top:14px;">
          A working demonstrator of AI-native supply-chain security: real SBOM and vulnerability
          scanning, EPSS and CISA KEV enrichment, and frontier-model reachability that cuts
          <strong>874 raw findings down to the 18 that actually matter</strong> — then drafts the
          reachability-gated fix. What we build, running.
        </p>
        <div class="cta-row" style="margin-top:26px;">
          <a href="/nineline" class="btn btn-primary">See NINELINE →</a>
          <a href="https://frontend-five-roan-63.vercel.app" class="btn btn-ghost" target="_blank" rel="noopener">Open the live demo ↗</a>
        </div>
      </div>
      <ul class="nl-stats">
        <li><span class="nl-num">874 → 18</span><span class="nl-lab">raw findings → require action</span></li>
        <li><span class="nl-num grad">−97.9%</span><span class="nl-lab">noise eliminated</span></li>
