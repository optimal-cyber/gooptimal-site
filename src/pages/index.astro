---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GatewayCanvas from "../components/GatewayCanvas.astro";
import VetBadge from "../components/VetBadge.astro";

const standards = [
  "NIST AI RMF", "OWASP LLM Top 10", "MITRE ATLAS", "NIST 800-207 Zero Trust",
  "CIS Benchmarks", "DISA STIG", "ISO 42001", "SOC 2",
];

// Advisory-led services — the four engagements Optimal runs. Ordered as a
// narrative arc: find it → prove it → build the controls → keep it governed.
const services = [
  {
    k: "01",
    title: "AI Security Assessment",
    body: "A structured evaluation of your AI systems, pipelines, and integrations — models, prompts, retrieval, tool calls, and the plumbing around them. We map the attack paths an adversary would actually take, measured against the OWASP LLM Top 10, MITRE ATLAS, and NIST AI RMF, and hand back findings you can act on — not a checklist.",
    accent: "var(--sunset)",
  },
  {
    k: "02",
    title: "Adversarial AI Testing",
    body: "Offensive testing of AI-enabled systems: prompt injection, jailbreaks, model and context manipulation, data and secret extraction, and abuse-case simulation. We find the failure before an adversary does — and show you exactly how it happened, and what closes it.",
    accent: "var(--steel)",
  },
  {
    k: "03",
    title: "Governed AI Engineering",
    body: "Our signature engagement. We design and stand up the access layer for AI in regulated environments — one authenticated gateway to every approved model, guardrails on every prompt, default-deny egress, and an audit trail joined by request ID. Built on our open-source Zero Trust reference architecture, in the cloud you already operate.",
    accent: "var(--coral)",
  },
  {
    k: "04",
    title: "Secure AI Adoption Advisory",
    body: "Help your teams adopt AI without flying blind. We build practical, engineering-grounded usage patterns, threat models, and secure-adoption roadmaps scoped to your risk profile — grounded in real attack paths, not paperwork. Your people learn the guardrails; you get the evidence they held.",
    accent: "var(--seafoam)",
  },
];

const flow = [
  { n: "Authorize", d: "Authenticate the caller through Cloudflare Access and Okta OIDC, then check the model and resource allowlist." },
  { n: "Guard", d: "Inline detection on prompt and response — injection, jailbreak, PII / DLP, secret exfiltration. Fail-closed." },
  { n: "Forward", d: "Proxy to the approved model — commercial, GovCloud, or self-hosted — through per-key LiteLLM virtual credentials." },
  { n: "Prove", d: "Write a structured audit row — JSON plus Postgres, joined by request ID — that you can hand to a reviewer." },
];

const work = [
  {
    tag: "Regulated cloud",
    title: "Governed AI inside the cloud you already operate",
    body: "Route agents and users to approved models with a full audit trail. Every request authorized, every token logged — without standing up a new accreditation boundary.",
    href: "/use-cases/regulated-cloud",
    cta: "Regulated cloud →",
  },
  {
    tag: "On-prem & air-gapped",
    title: "Frontier-class AI with zero egress",
    body: "Self-host the gateway and models where nothing leaves the wire. Default-deny egress is structural, not a checkbox — the same control bands, fully disconnected.",
    href: "/use-cases/air-gapped",
    cta: "On-prem & air-gapped →",
  },
  {
    tag: "Agentic workloads",
    title: "Keep autonomous agents accountable",
    body: "Per-key identity and rate limits, model and tool allowlists, and an audit of every call an agent makes — so autonomy never means unaccountable.",
    href: "/use-cases/agentic",
    cta: "Agentic workloads →",
  },
];

const faqs = [
  {
    q: "What does Optimal do?",
    a: "Optimal is an AI security advisory firm for regulated, federal, and defense missions. We assess and red-team AI systems, engineer the governed access layer that keeps them accountable, and advise teams on adopting AI safely. We're an SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB).",
  },
  {
    q: "Is Optimal a product company or a services firm?",
    a: "Advisory-led. We deliver engagements, not a SaaS subscription. The control pattern we implement is published as an open-source Zero Trust reference architecture — so you can read exactly what we build before we build it, and keep operating it yourself afterward.",
  },
  {
    q: "How do you test AI systems for vulnerabilities?",
    a: "We test real attack paths — prompt injection, model and context manipulation, data and secret extraction, and abuse-case simulation — scoped to your specific environment and risk profile rather than a generic checklist. Findings are measured against the OWASP LLM Top 10 and MITRE ATLAS and come with the evidence and the fix.",
  },
  {
    q: "What is prompt injection, and why does it matter?",
    a: "Prompt injection manipulates an AI system through crafted input, causing it to ignore its instructions, expose data, or take actions it shouldn't. It's one of the most active threats facing any organization deploying large language models and agents — and one of the first things we test.",
  },
  {
    q: "How do you help teams adopt AI safely?",
    a: "We build practical, engineering-grounded usage patterns, threat models, and secure-adoption roadmaps tied to real-world risk. We review how AI is actually being used, identify where data and access are exposed, and give your teams guardrails they can follow — so adoption moves fast without moving blind.",
  },
  {
    q: "Can Optimal work on federal or set-aside contracts?",
    a: "Yes. Optimal is an SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB), eligible for SDVOSB and VOSB set-aside contracts. We work across GovCloud, IL environments, on-prem, and fully air-gapped networks.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title="Optimal — AI security advisory for regulated & federal missions"
  description="Optimal is an AI security advisory firm. We assess and red-team AI systems, engineer the governed access layer that keeps them accountable, and advise teams on adopting AI safely — across GovCloud, on-prem, and air-gapped. An SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB)."
>
  <Header />

  <!-- HERO -->
  <section class="hero relative">
    <div class="glow"></div>
    <GatewayCanvas variant="hero" />
    <div class="container z">
      <span class="eyebrow">AI security advisory · Expertise-led, adversary-informed</span>
      <h1 class="display">Secure the AI<br /><span class="grad">your mission is betting on.</span></h1>
      <p class="lead">
        Optimal is an AI security advisory firm for regulated and federal missions. We assess your
        AI systems the way an adversary would, engineer the controls that keep them accountable, and
        help your teams adopt AI without losing the audit trail — across GovCloud, on-prem, and
        air-gapped.
      </p>
      <div class="cta-row">
        <a href="/contact" class="btn btn-primary">Book a scoping call →</a>
        <a href="#services" class="btn btn-ghost">See our services</a>
      </div>
      <div class="hero-meta muted">
        <span>Expertise-led, adversary-informed</span><span class="dot">•</span>
        <span>Sovereign by default</span><span class="dot">•</span>
        <span>SDVOSB-certified</span>
      </div>
    </div>
  </section>

  <!-- STANDARDS WALL (logo wall analogue) -->
  <section id="standards" class="section--tight standards">
    <div class="container">
      <p class="wall-label muted">We engineer to the standards that gate production AI</p>
      <div class="wall">
        {standards.map((s) => <span class="chip">{s}</span>)}
      </div>
      <div class="vet-strip">
        <VetBadge size={84} />
        <p class="vet-note muted">
          Optimal, LLC is a <strong>Service-Disabled Veteran-Owned Small Business</strong> —
          SBA-certified and eligible for veteran set-aside contracts.
        </p>
      </div>
    </div>
  </section>

  <!-- APPROACH / PHILOSOPHY -->
  <section id="approach" class="section approach relative">
    <div class="glow"></div>
    <div class="container z">
      <span class="eyebrow">Our approach</span>
      <h2 class="h2">Adversary-informed,<br />not compliance-driven.</h2>
      <div class="approach-body">
        <p>
          Most teams meet AI security through a checklist. We start from the adversary — how a prompt
          gets injected, how a model leaks its own context, how an agent is talked into acting outside
          its lane. Compliance frameworks are where we finish, engineering targets we build toward,
          never where we begin.
        </p>
        <p>
          Expertise leads every engagement. We use AI and our own open-source tooling to move
          faster, but the judgment — what to test, what a finding means, what to build — stays human.
          We don't hand you a product and walk away. We scope to your stack, your risk, and your
          environment, and leave you able to run what we build.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="section">
    <div class="container">
      <span class="eyebrow">What we do</span>
      <h2 class="h2">Four ways we secure AI for the mission.</h2>
      <p class="lead" style="margin-top:14px;">Assess it the way an adversary would. Prove the failure. Engineer the controls that stop it. Keep the whole program governed.</p>
      <div class="grid grid-2" style="margin-top:42px;">
        {services.map((c) => (
          <div class="card cap">
            <div class="cap-k" style={`color:${c.accent}`}>{c.k}</div>
            <h3>{c.title}</h3>
            <p class="muted">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="section how relative">
    <div class="glow"></div>
    <div class="container z">
      <span class="eyebrow">How the controls work</span>
      <h2 class="h2">Agents in. Approved resources out.<br />Everything in between, governed.</h2>
      <p class="lead" style="margin-top:14px;">The reference pattern behind our Governed AI Engineering work — the same open-source Zero Trust design we stand up in your environment.</p>
      <div class="flow">
        {flow.map((f, i) => (
          <div class="step">
            <div class="step-n">{String(i + 1).padStart(2, "0")}</div>
            <h4>{f.n}</h4>
            <p class="muted">{f.d}</p>
          </div>
        ))}
      </div>
      <p class="muted note">No wrapper, no SDK rewrite — point your existing OpenAI- or Anthropic-compatible client at the gateway and every call is governed and logged.</p>
    </div>
  </section>

  <!-- USE CASES -->
  <section id="work" class="section">
    <div class="container">
      <span class="eyebrow">Where we work</span>
      <h2 class="h2">Built for the missions that can&rsquo;t get it wrong.</h2>
      <div class="grid grid-3" style="margin-top:42px;">
        {work.map((w) => (
          <div class="card usecase">
            <span class="tag">{w.tag}</span>
            <h3>{w.title}</h3>
            <p class="muted">{w.body}</p>
            <a href={w.href} class="usecase-link">{w.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="section faq relative">
    <div class="glow"></div>
    <div class="container z">
      <span class="eyebrow">FAQ</span>
      <h2 class="h2">Questions we get first.</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>
              <span class="faq-q">{f.q}</span>
              <span class="faq-mark" aria-hidden="true"></span>
            </summary>
            <p class="muted faq-a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="section--tight">
    <div class="container">
      <blockquote class="quote">
        <p>&ldquo;We don&rsquo;t hand you a scan and walk away. We show you how an adversary gets in, engineer the controls that stop them, and leave you the evidence that they held.&rdquo;</p>
        <footer class="muted">Optimal — expertise-led AI security.</footer>
      </blockquote>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta relative">
    <div class="glow"></div>
    <GatewayCanvas variant="ambient" align="center" density={0.7} />
    <div class="container z cta-inner">
      <h2 class="display" style="font-size:clamp(2rem,5vw,3.4rem);">Let&rsquo;s secure<br />your AI.</h2>
      <p class="lead" style="margin:18px auto 0;">Tell us your environment, the models you&rsquo;re adopting, and where you&rsquo;re worried. We&rsquo;ll scope an engagement — assessment, red team, governed engineering, or advisory — across GovCloud, on-prem, or air-gapped.</p>
      <a href="/contact" class="btn btn-primary" style="margin-top:28px;">Book a scoping call →</a>
    </div>
  </section>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
</Layout>

<style>
  /* HERO */
  .hero { padding: clamp(72px, 12vw, 150px) 0 clamp(48px, 7vw, 90px); }
  .hero .eyebrow { margin-bottom: 22px; }
  .hero h1 { margin-bottom: 24px; }
  .hero .lead { font-size: clamp(17px, 2.2vw, 21px); }
  .cta-row { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 34px; }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-top: 30px; font-size: 13px; }
  .hero-meta .dot { opacity: 0.4; }

  /* STANDARDS WALL */
  .standards { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--surface); }
  .wall-label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.16em; text-align: center; margin-bottom: 22px; }
  .wall { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .chip {
    font-family: var(--font-display); font-weight: 500; font-size: 14px;
    color: var(--text-dim); border: 1px solid var(--rule); border-radius: 999px;
    padding: 8px 16px; transition: color .2s, border-color .2s;
  }
  .chip:hover { color: var(--text); border-color: var(--rule-strong); }
  .vet-strip {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 14px 18px; margin-top: 26px; padding-top: 24px;
    border-top: 1px solid var(--rule);
  }
  .vet-note { font-size: 13px; max-width: 52ch; text-align: center; }
  .vet-note strong { color: var(--text); font-weight: 600; }

  /* APPROACH */
  .approach-body { max-width: 68ch; margin-top: 26px; display: grid; gap: 18px; }
  .approach-body p { color: var(--text-dim); font-size: clamp(15px, 1.8vw, 17px); line-height: 1.75; }

  /* SERVICES (cap cards) */
  .cap-k { font-family: var(--font-display); font-size: 13px; font-weight: 700; letter-spacing: 0.1em; margin-bottom: 14px; }
  .cap h3 { font-size: 1.35rem; margin-bottom: 10px; }
  .cap p { font-size: 15px; line-height: 1.7; }

  /* HOW */
  .how { background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .flow { display: grid; gap: 20px; margin-top: 42px; }
  .step { padding: 24px; border: 1px solid var(--rule); border-radius: var(--radius); background: var(--surface-2); }
  .step-n { font-family: var(--font-display); font-weight: 700; color: var(--sunset); font-size: 14px; letter-spacing: 0.1em; margin-bottom: 12px; }
  .step h4 { font-size: 1.15rem; margin-bottom: 8px; }
  .step p { font-size: 14px; line-height: 1.65; }
  .note { margin-top: 28px; font-size: 14px; max-width: 70ch; }
  @media (min-width: 860px) { .flow { grid-template-columns: repeat(4, 1fr); } }

  /* USE CASES */
  .usecase h3 { font-size: 1.2rem; margin: 14px 0 10px; }
  .usecase p { font-size: 14px; line-height: 1.7; }
  .usecase-link { display: inline-block; margin-top: 16px; color: var(--sunset); font-size: 14px; font-weight: 600; }
  .usecase-link:hover { color: var(--ember); }

  /* FAQ */
  .faq { background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .faq-list { margin-top: 38px; max-width: 78ch; border-top: 1px solid var(--rule); }
  .faq-item { border-bottom: 1px solid var(--rule); }
  .faq-item summary {
    display: flex; align-items: center; justify-content: space-between; gap: 18px;
    padding: 20px 4px; cursor: pointer; list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-q { font-family: var(--font-display); font-weight: 600; font-size: clamp(1rem, 2vw, 1.15rem); color: var(--text); letter-spacing: -0.01em; }
  .faq-mark { position: relative; flex: 0 0 auto; width: 14px; height: 14px; }
  .faq-mark::before, .faq-mark::after {
    content: ""; position: absolute; background: var(--sunset); transition: transform .2s ease, opacity .2s ease;
  }
  .faq-mark::before { top: 6px; left: 0; width: 14px; height: 2px; }
  .faq-mark::after { top: 0; left: 6px; width: 2px; height: 14px; }
  .faq-item[open] .faq-mark::after { transform: scaleY(0); opacity: 0; }
  .faq-a { padding: 0 4px 22px; font-size: 15px; line-height: 1.75; max-width: 70ch; }

  /* QUOTE */
  .quote { margin: 0; border-left: 3px solid var(--sunset); padding: 6px 0 6px 28px; max-width: 60ch; }
  .quote p { font-family: var(--font-display); font-size: clamp(1.2rem, 2.6vw, 1.8rem); line-height: 1.35; letter-spacing: -0.02em; }
  .quote footer { margin-top: 16px; font-size: 14px; }

  /* CTA */
  .cta { background: var(--surface); border-top: 1px solid var(--rule); }
  .cta-inner { text-align: center; max-width: 720px; margin: 0 auto; }
</style>
