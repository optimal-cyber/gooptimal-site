---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
}
const {
  title = "Optimal — governed AI for regulated & federal missions",
  description = "Optimal is an AI security advisory firm. We assess and red-team AI systems, engineer the governed access layer that keeps them accountable, and advise teams on adopting AI safely — across GovCloud, on-prem, and air-gapped. An SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB).",
  image = "/optimal-social-preview.png",
  keywords = "SDVOSB, Service-Disabled Veteran-Owned Small Business, VOSB, Veteran-Owned Small Business, SBA VetCert, veteran-owned AI security, governed AI, secure AI gateway, AI guardrails, Zero Trust AI, GovCloud AI, air-gapped AI, AI red-teaming, NIST AI RMF, OWASP LLM Top 10",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

// Site-wide Organization structured data — advertises the SDVOSB credential to
// Google, AI Overviews, and LLM crawlers as machine-readable fact, not just prose.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Optimal",
  legalName: "Optimal, LLC",
  url: "https://gooptimal.io",
  logo: "https://gooptimal.io/optimal-horizon-512.png",
  image: "https://gooptimal.io/optimal-social-preview.png",
  email: "ryan@gooptimal.io",
  slogan: "Sovereign by default.",
  description:
    "Optimal is an AI security advisory firm for regulated and federal missions — AI security assessments, adversarial (red-team) AI testing, governed AI engineering, and secure-adoption advisory. An SBA-certified Service-Disabled Veteran-Owned Small Business (SDVOSB).",
  makesOffer: [
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "AI Security Assessment",
        description:
          "Structured evaluation of AI systems, pipelines, and integrations against real adversary attack paths, measured to the OWASP LLM Top 10, MITRE ATLAS, and NIST AI RMF.",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Adversarial AI Testing",
        description:
          "Offensive red-team testing of AI-enabled systems — prompt injection, model manipulation, data extraction, and abuse-case simulation.",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Governed AI Engineering",
        description:
          "Design and stand-up of a Zero Trust access layer for AI — authenticated gateway, prompt guardrails, default-deny egress, and an auditable trail — in the client's environment.",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Secure AI Adoption Advisory",
        description:
          "Practical, engineering-grounded usage patterns, threat models, and secure-adoption roadmaps scoped to an organization's risk profile.",
      },
    },
  ],
  knowsAbout: [
    "Governed AI",
    "Secure AI gateway",
    "AI guardrails",
    "Zero Trust architecture",
    "AI red-teaming",
    "NIST AI RMF",
    "Service-Disabled Veteran-Owned Small Business",
  ],
  hasCredential: [
    {
      "@type": "EducationalOccupationalCredential",
      credentialCategory: "certification",
      name: "Service-Disabled Veteran-Owned Small Business (SDVOSB)",
      description:
        "SBA-certified Service-Disabled Veteran-Owned Small Business and Veteran-Owned Small Business via the SBA Veteran Small Business Certification (VetCert) program. Eligible for SDVOSB and VOSB set-aside contracts.",
      url: "https://search.certifications.sba.gov/",
      recognizedBy: {
        "@type": "GovernmentOrganization",
        name: "U.S. Small Business Administration",
        url: "https://www.sba.gov",
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Optimal" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/optimal-horizon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/optimal-horizon-32.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />
  </head>
  <body>
    <slot />
    <!-- Secure Gateway Constellation — inits only on pages with a [data-gateway-3d] canvas -->
    <script is:inline defer src="/js/gateway-3d.js"></script>
  </body>
</html>
