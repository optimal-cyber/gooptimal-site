---
// SDVOSB credential badge — Optimal, LLC is SBA-certified via the VetCert program.
// Links to the public SBA certification registry for verification.
// variant: "full" (card with sub-line) · "inline" (compact pill)
interface Props {
  variant?: "full" | "inline";
  class?: string;
}
const { variant = "full", class: className = "" } = Astro.props;
const href = "https://search.certifications.sba.gov/";
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class:list={["vetbadge", variant, className]}
  aria-label="Optimal is a certified Service-Disabled Veteran-Owned Small Business — verify on the SBA VetCert registry"
>
  <svg class="vb-star" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
    <path
      fill="currentColor"
      d="M12 2l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545L12 17.5l-5.878 3.09 1.123-6.545L2.489 8.91l6.572-.955z"
    ></path>
  </svg>
  <span class="vb-text">
    <strong>SDVOSB Certified</strong>
    {variant === "full" && (
      <span class="vb-sub">Service-Disabled Veteran-Owned Small Business · SBA VetCert</span>
    )}
  </span>
</a>

<style>
  .vetbadge {
    display: inline-flex; align-items: center; gap: 10px;
    border: 1px solid var(--rule-strong); border-radius: 999px;
    color: var(--text); transition: border-color .2s ease, background .2s ease;
  }
  .vetbadge:hover { border-color: var(--sunset); background: rgba(255, 138, 61, 0.06); }
  .vb-star { color: var(--sunset); flex: none; }
  .vb-text { display: grid; }
  .vb-text strong {
    font-family: var(--font-display); font-weight: 600; letter-spacing: 0.02em;
  }

  /* full — card-style credential */
  .vetbadge.full { padding: 10px 18px 10px 14px; }
  .full .vb-text strong { font-size: 14px; }
  .full .vb-sub { font-size: 11px; color: var(--text-dim); letter-spacing: 0.01em; }

  /* inline — compact pill */
  .vetbadge.inline { padding: 6px 14px 6px 11px; gap: 8px; }
  .inline .vb-star { width: 15px; height: 15px; }
  .inline .vb-text strong { font-size: 12.5px; }
</style>
