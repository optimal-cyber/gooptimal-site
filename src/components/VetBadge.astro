---
// SDVOSB certification seal — Optimal, LLC is SBA-certified via the VetCert
// program. Original laurel-wreath emblem (public/sdvosb-emblem.svg), linked to
// the public SBA certification registry for verification.
interface Props {
  size?: number;
  class?: string;
}
const { size = 64, class: className = "" } = Astro.props;
---

<a
  href="https://search.certifications.sba.gov/"
  target="_blank"
  rel="noopener"
  class:list={["vetseal", className]}
  aria-label="Optimal is a certified Service-Disabled Veteran-Owned Small Business (SDVOSB) — verify on the SBA VetCert registry"
>
  <img
    src="/sdvosb-emblem.svg"
    width={size}
    height={size}
    loading="lazy"
    decoding="async"
    alt="SDVOSB — Service-Disabled Veteran-Owned Small Business, SBA VetCert certified"
  />
</a>

<style>
  .vetseal { display: inline-block; line-height: 0; transition: transform .2s ease, filter .2s ease; }
  .vetseal:hover { transform: translateY(-1px); filter: drop-shadow(0 8px 20px rgba(255, 138, 61, 0.2)); }
  .vetseal img { display: block; }
</style>
