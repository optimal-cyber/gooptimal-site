---
import VetBadge from "./VetBadge.astro";

const year = 2026;
const cols = [
  {
    title: "Services",
    links: [
      { href: "/#services", label: "AI Security Assessment" },
      { href: "/#services", label: "Adversarial AI Testing" },
      { href: "/#services", label: "Governed AI Engineering" },
      { href: "/#services", label: "Secure AI Adoption Advisory" },
    ],
  },
  {
    title: "Use cases",
    links: [
      { href: "/use-cases/regulated-cloud", label: "Regulated cloud" },
      { href: "/use-cases/air-gapped", label: "On-prem & air-gapped" },
      { href: "/use-cases/agentic", label: "Agentic workloads" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/contact", label: "Contact" },
      { href: "https://github.com/optimal-cyber/AI-Gateway", label: "Reference architecture ↗" },
    ],
  },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="top">
      <div class="brandcol">
        <div class="brand">
          <img src="/optimal-horizon.svg" alt="" width="26" height="26" class="mark" aria-hidden="true" />
          <span class="wordmark">OPTIMAL</span>
        </div>
        <p class="muted blurb">AI security advisory for the organizations that keep critical missions moving. We assess, red-team, and engineer governed AI in your environment — sovereign by default.</p>
        <VetBadge size={76} class="footer-vet" />
      </div>
      {cols.map((c) => (
        <div class="col">
          <h4>{c.title}</h4>
          <ul>{c.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
        </div>
      ))}
    </div>
    <div class="bottom">
      <span class="muted">© {year} Optimal, LLC. Sovereign by default.</span>
      <span class="muted">SDVOSB · SBA-certified Veteran-Owned · Zero Trust · NIST AI RMF · OWASP LLM Top 10</span>
    </div>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--rule); padding: 64px 0 36px; background: var(--surface); }
  .top { display: grid; gap: 40px; grid-template-columns: 1fr; }
  .brandcol { max-width: 360px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .brand .mark { width: 26px; height: 26px; border-radius: 50%; display: block; }
  .wordmark { font-family: var(--font-display); font-weight: 600; letter-spacing: 0.22em; font-size: 15px; }
  .blurb { font-size: 14px; line-height: 1.7; }
  .footer-vet { margin-top: 20px; }
  .col h4 { font-family: var(--font-body); font-size: 12px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-faint); margin-bottom: 14px; }
  .col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
  .col a { font-size: 14px; color: var(--text-dim); transition: color .2s ease; }
  .col a:hover { color: var(--sunset); }
  .bottom { display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--rule); font-size: 13px; }
  @media (min-width: 820px) { .top { grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 48px; } }
</style>
